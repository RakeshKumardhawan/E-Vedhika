rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        ('email' in request.auth.token && request.auth.token.email.lower() == 'rakeshkumardhawan123@gmail.com')
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(field) { return incoming()[field] == request.auth.uid; }

    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /admins/{adminId} {
      allow read: if isValidId(adminId);
      allow write: if false;
    }

    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid && (!('status' in incoming()) || incoming().status == existing().status));
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && (isOwner('uid') || isOwner('authorId'));
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isOwner('uid');
        allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /chat/{msgId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner('uid');
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
    }

    match /problems/{problemId} {
      allow read: if true;
      allow create: if isSignedIn() && (isOwner('uid') || isOwner('userId') || isOwner('authorId') || !('uid' in incoming())); 
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid && (!('status' in incoming()) || incoming().status == existing().status));
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner('uid');
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
    }

    match /gos_formats/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner('uploadedBy');
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uploadedBy == request.auth.uid);
    }

    match /forms/{formId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (existing().uid == request.auth.uid || existing().uid == 'all' || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow update: if settingId == 'site_stats' || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /app_errors/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /security_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create, update: if isAdmin() || isSignedIn();
      allow delete: if isAdmin();
    }

    match /home_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny (fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
