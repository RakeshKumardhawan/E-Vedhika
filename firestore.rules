rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email.lower() == 'rakeshkumardhawan123@gmail.com'
      ); 
    }

    // Public Collections
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      }
    }

    match /updates/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suggestions/{id} {
      allow read: if true;
      allow create: if true; // ALLOW ANONYMOUS SUBMISSION
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /forms/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /chat/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /problems/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /requests/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if false;
    }

    match /security_logs/{id} {
      allow read, write: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /usernames/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
